    {
      "id": "8TKlvWAF8elJQs-HA8G9C",
      "type": "text",
      "x": 1450.7050712593602,
      "y": 202.1999021178039,
      "width": 373.280029296875,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "b8M",
      "roundness": null,
      "seed": 1251057938,
      "version": 1796,
      "versionNonce": 54850830,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774355533715,
      "link": null,
      "locked": false,
      "text": "1. Constructs an \"inverted\" DAG, indicating\n   the order in which to analyse the claims.\n2. Sends the claims to the analysis workflow\n   by injecting the child results each time\n3. Reconstructs the fully analyzed DAG\n\nThe verifiability E claims are left untouched. \nThe Writer will choose to mention them or not. \n\nThe verifiability A claims are merged into one \nclaim: \"Common Knowledge Questions\", and then \nthe Writer will choose to mention them or not. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Constructs an \"inverted\" DAG, indicating\n   the order in which to analyse the claims.\n2. Sends the claims to the analysis workflow\n   by injecting the child results each time\n3. Reconstructs the fully analyzed DAG\n\nThe verifiability E claims are left untouched. \nThe Writer will choose to mention them or not. \n\nThe verifiability A claims are merged into one \nclaim: \"Common Knowledge Questions\", and then \nthe Writer will choose to mention them or not. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
