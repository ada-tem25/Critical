    {
      "id": "mN7dY2bzEnK6F3Lm0IKVZ",
      "type": "text",
      "x": 706.8175824966866,
      "y": 792.2875696322877,
      "width": 367.5519104003906,
      "height": 380,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 40,
      "groupIds": [
        "TSOxQErKi9WvaVn6Ozjm_"
      ],
      "frameId": null,
      "index": "b9aG",
      "roundness": null,
      "seed": 18841742,
      "version": 2368,
      "versionNonce": 879241298,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774362888553,
      "link": null,
      "locked": false,
      "text": "Redacts a full article in the language of the \nuser, weighting the claims properly, highlighting \nthe rhetorics, exposing the relevant data, \nconstructing a coherent argument, lead \ntowards a conclusion. \n\nAt the end, can produce a truth token to \nspecify on the article (ex: \"True\", \"False\", \n\"Misleading\", \"Partially True\"...). Those are \nmostly useful for the fact-checking \nfocused articles. \n\nIf all the claims are type A, redacts a \nsimple chat answer. If all the claims are \ntype E, return an error chat answer. \nIf there are a few type A or E claims in a big \nDAG, it is up to the Writer to judge if it is \nnecessary to mention them or not.  \n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redacts a full article in the language of the \nuser, weighting the claims properly, highlighting \nthe rhetorics, exposing the relevant data, \nconstructing a coherent argument, lead \ntowards a conclusion. \n\nAt the end, can produce a truth token to \nspecify on the article (ex: \"True\", \"False\", \n\"Misleading\", \"Partially True\"...). Those are \nmostly useful for the fact-checking \nfocused articles. \n\nIf all the claims are type A, redacts a \nsimple chat answer. If all the claims are \ntype E, return an error chat answer. \nIf there are a few type A or E claims in a big \nDAG, it is up to the Writer to judge if it is \nnecessary to mention them or not.  \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
